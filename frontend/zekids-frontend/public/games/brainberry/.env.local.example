# Database Configuration
DATABASE_URL="file:./dev.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://username:password@localhost:5432/brainberry"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL='supabase-url-here'
NEXT_PUBLIC_SUPABASE_ANON_KEY='supabase-anon-key-here'
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Google Gemini AI Configuration (FREE!)
GEMINI_API_KEY="your-gemini-api-key"

# Ready Player Me Configuration (FREE!)
RPM_API_KEY="your-readyplayer-me-api-key"
RPM_APP_ID="your-readyplayer-me-app-id"
RPM_SUBDOMAIN="your-subdomain.readyplayer.me"
NEXT_PUBLIC_RPM_SUBDOMAIN=brainberry

# ElevenLabs TTS Configuration (Optional)
ELEVENLABS_API_KEY="your-elevenlabs-api-key-optional"

# Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Data Retention (days)
DATA_RETENTION_DAYS=365

# COPPA Compliance
COPPA_COMPLIANCE_ENABLED=true
PARENTAL_CONSENT_REQUIRED=true

# Monitoring and Logging
LOG_LEVEL="info"
ENABLE_AUDIT_LOGGING=true

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
CHILD_SESSION_TIMEOUT_MINUTES=30

# AI Service Configuration
AI_SERVICE_TIMEOUT_MS=5000
AI_FALLBACK_ENABLED=true
AI_CACHE_ENABLED=true
AI_CACHE_TTL_HOURS=24